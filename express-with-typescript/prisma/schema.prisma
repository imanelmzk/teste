// 1* Generator : pour générer le client
generator client{
  provider = "prisma-client-js"
}

// 2* Datasource :  pour définir la BDD
datasource db {
  provider = "postgresql"
  url      = "file:./dev.db"
}

// 3* Model = nos tables
model User{
  id    Int @id @default(autoincrement())
  name  String
  email String
}
